//Letsc check a number is palindrome or not
//Leetcode Problem Link: https://leetcode.com/problems/palindrome-number/
// Approach:
// 1. Negative numbers cannot be palindrome.
// 2. Reverse the digits of the number.
// 3. Compare reversed number with original number.
// 4. If both are equal, the number is palindrome.


//Code:

class Solution {
    public boolean isPalindrome(int x) {
        if(x<0){
            return false;
        }
        int rev=0;
        int n=x;
        while(x!=0){
            int d=x%10;
            rev=rev*10+d;
            x=x/10;
        }
        return rev==n;
    }
}



//Time Complexity: O(logn)
//Space Complexity: O(1)
