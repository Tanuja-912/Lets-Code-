Insert element at sepcific position of array:

class Solution {
    public static int[] InsertAtSpecificPosition(int[] arr,int x,int pos){
        int[] newarr=new int[arr.length+1];
        for(int i=0;i<pos;i++){
            newarr[i]=arr[i];
        }
        newarr[pos]=x;
        for(int i=pos;i<arr.length;i++){
            newarr[i+1]=arr[i];
        }
        return newarr;
    }
}
    public class Main {
        public static void main(String[] args){
        int[] arr = {1,2,3,5,6};
        int x=4;
        int pos=1;
        arr=Solution.InsertAtSpecificPosition(arr,x,pos);
        for(int num: arr){
            System.out.print(num+" ");
        }
       System.out.println(); 
    }
}
