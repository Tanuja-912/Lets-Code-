class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int n=arr.length;
        int largest=-1;
        int second_largest=-1;
        for(int i=0;i<n;i++){
            if(arr[i]>largest){
                second_largest=largest;
                largest=arr[i];
            }
            else if(arr[i]>second_largest && largest>arr[i]){
                second_largest=arr[i];
            }
        }
        return second_largest;
    }
}
