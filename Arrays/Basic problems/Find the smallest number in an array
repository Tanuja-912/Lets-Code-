import java.util.*;
import java.lang.*;
import java.io.*;

class GFG {
	public static void main (String[] args) {
		//code here
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		int [] arr = new int[n];
		for(int i=0;i<n;i++){
		    arr[i] = sc.nextInt();
		}
		int min = arr[0];
		for(int j=1 ; j< n ; j++){
		    if (arr[j]<min){
		        min = arr[j];
		    }
		}
		System.out.println(min);
	}
}
