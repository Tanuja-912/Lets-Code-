Day 5:
Best time to buy and sell stock
Time complexity: O(n)

Java implementation:

class Solution {
    public int maxProfit(int[] nums) {
        int min=Integer.MAX_VALUE;
        int max=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]<min){
                min=nums[i];
            }
            else if(nums[i]>min){
                max= Math.max(nums[i]-min , max);
            }
        }
        return max;
    }
}
